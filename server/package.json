{
  "name": "alumni-influence-hub-server",
  "version": "1.0.0",
  "description": "Alumni Influencers API – Phantasmagoria Ltd × University of Eastminster",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --testTimeout=15000 --forceExit --runInBand"
  },
  "jest": {
    "testMatch": [
      "**/src/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/\\._.*\\.test\\.js$/"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
