

# Port the Express server listens on
PORT=3000

# Environment: development | production | test
NODE_ENV=development


# Secret used to sign JWT tokens — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=eastminster-alumni-secret-changeme

# How long JWT tokens last before expiring (e.g. 24h, 7d, 30m)
JWT_EXPIRES_IN=24h

# How many minutes of inactivity before a session is invalidated
# Leave blank to disable idle timeout
SESSION_IDLE_TIMEOUT_MINUTES=30

# University email domain required for alumni registration
UNIVERSITY_DOMAIN=alumni.eastminster.ac.uk


# Allowed origins for CORS — use * for development, set exact URL(s) in production
# Multiple origins: CORS_ORIGIN=http://localhost:3001,https://yourdomain.com
CORS_ORIGIN=http://localhost:3001


# SMTP server hostname (e.g. smtp.gmail.com, smtp.mailtrap.io)
SMTP_HOST=smtp.mailtrap.io

# SMTP port — usually 587 (TLS) or 465 (SSL)
SMTP_PORT=587

# Use SSL (true) or TLS/STARTTLS (false)
SMTP_SECURE=false

# SMTP login credentials
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# From address shown in outgoing emails
EMAIL_FROM="Alumni Influencers" <noreply@eastminster.ac.uk>

# Base URL of the frontend client — used to build links in emails
# e.g. verify link becomes: CLIENT_URL/#verify?token=...
CLIENT_URL=http://localhost:3001

# How long password reset tokens are valid (minutes)
RESET_TOKEN_EXPIRES_MINUTES=30


# Prefix prepended to all generated API keys
# e.g. east_ produces keys like: east_a3f9bc...
API_KEY_PREFIX=east_


# Directory where uploaded profile photos are saved (relative to project root)
UPLOAD_DIR=./uploads

# Maximum file size for photo uploads in megabytes
MAX_FILE_SIZE_MB=5


# UTC hour (0-23) when the bidding window closes each day
# Bids placed after this hour are rejected until midnight
BID_CLOSE_HOUR_UTC=18

# UTC hour (0-23) when the automated winner selection cron job runs
# Should match or come after BID_CLOSE_HOUR_UTC
WINNER_SELECT_HOUR_UTC=18