<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">🎓 Alumni Influencers</a>
            <ul class="nav-links">
                <li><a href="/alumnis">Directory</a></li>
                <% if (loggedIn) { %>
                    <li><a href="/dashboard">Dashboard</a></li>
                    <li><a href="/api-keyss">API Keys</a></li>
                    <li><a href="/auth/logout" class="btn-logout">Logout</a></li>
                <% } else { %>
                    <li><a href="/login" class="btn-login">Login</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <main class="container content-area">
        <%- body %>
    </main>

    <footer class="footer">
        <p>&copy; 2026 University of Eastminster Analytics Portal</p>
    </footer>

    <script src="/app.js"></script>
</body>
</html>